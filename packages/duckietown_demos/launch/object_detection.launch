<?xml version="1.0" encoding="utf-8"?>
<launch>
	<arg name="veh" default="$(env VEHICLE_NAME)"/>
    <arg name="demo_name" value="object_detection"/>

	<include file="$(find duckietown_demos)/launch/master.launch">
		<arg name="veh" value="$(arg veh)"/>
        <arg name="demo_name" value="$(arg demo_name)"/>
		<arg name="param_file_name" value="default" />

		<!-- Object detection (standalone: publishes wheel commands directly) -->
		<arg name="object_detection" value="true"/>
	</include>
</launch>
